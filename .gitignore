# ==============================================
# Keep these files (use ! to negate ignore)
# ==============================================

# Keep important config files
!.gitignore
!README.md
!package.json
!.editorconfig
!.prettierrc
!.eslintrc*

# Keep essential assets
!assets/css/
!assets/js/
!assets/images/
!assets/fonts/

# Keep all HTML files
!*.html

# Keep documentation
!docs/README.md
!docs/*.md
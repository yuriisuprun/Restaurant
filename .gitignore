# ==============================================
# Ocean Table Restaurant Website - .gitignore
# ==============================================

# --- Operating system --------------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows
[Dd]esktop.ini
[Dd]$RECYCLE.BIN/
[Ee]hthumbs.db
[Tt]humbs.db
[Tt]humbs.db:encryptable
*.cab
*.msi
*.msm
*.msp
*.lnk
*.stackdump

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# --- Editors & IDEs ----------------------------------------------------------

# JetBrains / IntelliJ
.idea/
*.iml
*.iws

# VS Code — commit shared settings if you rely on defaults
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# Sublime Text
*.sublime-workspace
*.sublime-project
*.tmPreferences.cache
*.tmLanguage.cache

# Vim / Emacs
*.sw[a-p]
.Session.vim
.netrwhist
\#*\#
/.emacs.desktop
/.emacs.desktop.lock

# --- Dependencies & installs (tooling added later) ---------------------------

node_modules/
.npm
.pnp
.pnp.*

# Yarn 2+
.yarn/cache
.yarn/install-state.gz
.yarn/unplugged
.yarn/build-state.yml
.yarn/*-installer

# Logs from package managers / CLIs

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log

# --- Build outputs & caches --------------------------------------------------

dist/
build/
out/

.next/
.nuxt/
.parcel-cache/
.vite/

.cache/
.temp/
.tmp/
temp/
tmp/

.eslintcache
.stylelintcache
.rpt2_cache/
.turbo/

# --- Tests & coverage (when tooling exists) ----------------------------------
coverage/
.nyc_output
*.lcov

cypress/videos/
cypress/screenshots/

test-results/
playwright-report/
playwright/.cache/
.jest/

# --- Secrets & environment ----------------------------------------------------

.env
.env.*
!.env.example
!.env.sample
!.env.*.example

*.pem
*.key

# --- Local services & overrides ----------------------------------------------

docker-compose.override.yml
Dockerfile.local

# Deploy platform metadata (credentials live in provider dashboard / CI secrets)
.vercel/
.netlify/
firebase-debug.log
firebase-debug.*.log

# --- Miscellaneous ------------------------------------------------------------

*.tgz

# Local databases / SQLite artifacts
*.db
*.sqlite
*.sqlite3

# Backups made by editors/tools
*.backup
*.bak
*.orig
